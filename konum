-- =====================
-- KONUM GÜNCELLEME
-- =====================
local lastPos = Vector3.new(0, 0, 0)

RunService.Heartbeat:Connect(function()
    local character = player.Character
    if not character then return end

    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local pos = hrp.Position
    local speed = (pos - lastPos).Magnitude / RunService.Heartbeat:Wait() -- yaklaşık hız

    -- Hız hesabı için Humanoid kullan (daha doğru)
    local humanoid = character:FindFirstChild("Humanoid")
    local walkSpeed = humanoid and math.floor(humanoid.WalkSpeed) or 0
    local moveVel = hrp.Velocity
    local currentSpeed = math.floor(Vector3.new(moveVel.X, 0, moveVel.Z).Magnitude)

    xLabel.Text = string.format("%.1f", pos.X)
    yLabel.Text = string.format("%.1f", pos.Y)
    zLabel.Text = string.format("%.1f", pos.Z)
    speedLabel.Text = currentSpeed .. " st/s"

    lastPos = pos
end)
